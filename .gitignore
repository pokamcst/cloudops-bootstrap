# =============================================================================
# CloudOps Bootstrap — .gitignore
# =============================================================================

# ----------------------------- Terraform ------------------------------------
**/.terraform/*
*.tfstate
*.tfstate.*
crash.log
crash.*.log
*.tfvars
*.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraform.tfstate.lock.info
.terraformrc
terraform.rc
*tfplan*
.terraform.lock.hcl

# ----------------------------- Secrets & Env --------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.p12

# ----------------------------- Python ---------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
.pytest_cache/
.coverage
htmlcov/
*.cover

# ----------------------------- Java / Maven ---------------------------------
target/
*.jar
*.war
*.class
.mvn/wrapper/maven-wrapper.jar

# ----------------------------- Node.js --------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ----------------------------- Docker ---------------------------------------
docker-compose.override.yml

# ----------------------------- IDE / Editor ---------------------------------
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.iml

# ----------------------------- OS -------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# ----------------------------- Logs -----------------------------------------
logs/
*.log
dev-debug.log

# Task files
# tasks.json
# tasks/ 
